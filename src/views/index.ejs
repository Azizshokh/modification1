<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PetFood Admin — Dashboard</title>
  <link rel="icon" type="image/png" href="/img/favicon.png" />
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
  <div class="shell">

    <%- include('partials/sidebar', { page: 'home' }) %>

      <main class="main">
        <div class="topbar">
          <div class="topbar-title">Dashboard</div>
          <div class="topbar-actions">
            <a href="/admin/product/all" class="btn-primary">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
              New Product
            </a>
          </div>
        </div>

        <div class="page-content">
          <!-- Hero -->
          <div class="hero-card">
            <div class="hero-tag">🐾 Welcome back</div>
            <div class="hero-title">Manage Your<br><span>PetFood</span> Empire</div>
            <div class="hero-sub">Track your products, orders, and customers all in one elegant dashboard designed for
              pet food excellence.</div>
          </div>

          <!-- Stats -->
          <div class="stats-row">
            <div class="stat-card teal">
              <div class="stat-icon teal">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path
                    d="M21 10V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14" />
                </svg>
              </div>
              <div class="stat-label">Total Products</div>
              <div class="stat-value">
                <%= stats.totalProducts %>
              </div>
              <div class="stat-change">↑ 4 this week</div>
            </div>
            <div class="stat-card red">
              <div class="stat-icon red">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                </svg>
              </div>
              <div class="stat-label">Registered Users</div>
              <div class="stat-value">
                <%= stats.totalUsers %>
              </div>
              <div class="stat-change">↑ 12 this month</div>
            </div>
            <div class="stat-card green">
              <div class="stat-icon green">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                </svg>
              </div>
              <div class="stat-label">Active Listings</div>
              <div class="stat-value">
                <%= stats.activeListings %>
              </div>
              <div class="stat-change">↑ 2 today</div>
            </div>
            <div class="stat-card neutral">
              <div class="stat-icon teal">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
              </div>
              <div class="stat-label">Paused Items</div>
              <div class="stat-value">
                <%= stats.pausedItems %>
              </div>
              <div class="stat-change" style="color:#8a5a00">— Needs review</div>
            </div>
          </div>

          <!-- Recent Products Table -->
          <div class="section-header">
            <span class="section-title">Recent Products</span>
            <a href="/admin/product/all" class="btn-ghost">View All</a>
          </div>
          <div class="table-card">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Product Name</th>
                  <th>Category</th>
                  <th>Price</th>
                  <th>Stock</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% recentProducts.forEach((p, i)=> { %>
                  <tr>
                    <td>
                      <%= i + 1 %>
                    </td>
                    <td>
                      <%= p.productName %>
                    </td>
                    <td>
                      <%= p.productCollection %>
                    </td>
                    <td>$<%= p.productPrice %>
                    </td>
                    <td>
                      <%= p.productLeftCount %>
                    </td>
                    <td><span class="badge <%= p.productStatus === 'PROCESS' ? 'active' : 'pause' %>">
                        <%= p.productStatus %>
                      </span></td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </main>

  </div>
  <script src="/js/utils.js"></script>
</body>

</html>