<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PetFood Admin — Users</title>
  <link rel="icon" type="image/png" href="/img/favicon.png" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/users.css" />
</head>

<body>
  <div class="shell">

    <%- include('partials/sidebar', { page: 'users' }) %>

      <main class="main">
        <div class="topbar">
          <div class="topbar-title">User Management</div>
        </div>

        <div class="page-content">
          <!-- Status Cards -->
          <div class="stats-row">
            <div class="stat-card teal">
              <div class="stat-icon teal">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                  <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
              </div>
              <div class="stat-label">Total Users</div>
              <div class="stat-value">
                <%= stats.totalUsers %>
              </div>
              <div class="stat-change">↑ All members</div>
            </div>
            <div class="stat-card green">
              <div class="stat-icon green">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                  <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
              </div>
              <div class="stat-label">Active Users</div>
              <div class="stat-value">
                <%= stats.activeUsers %>
              </div>
              <div class="stat-change">✓ Verified</div>
            </div>
            <div class="stat-card" style="--teal: #ff9800;">
              <div class="stat-icon" style="background: #fff3e0;">
                <svg viewBox="0 0 24 24" fill="none" stroke="#ff9800" stroke-width="2" stroke-linecap="round"
                  stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <line x1="12" y1="8" x2="12" y2="12" />
                  <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
              </div>
              <div class="stat-label">Blocked Users</div>
              <div class="stat-value">
                <%= stats.blockedUsers %>
              </div>
              <div class="stat-change">⚠ Restricted</div>
            </div>
            <div class="stat-card red">
              <div class="stat-icon red">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 4 21 4 23 6 23 20a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V6" />
                  <line x1="10" y1="9" x2="14" y2="9" />
                  <line x1="10" y1="13" x2="14" y2="13" />
                  <line x1="10" y1="17" x2="14" y2="17" />
                </svg>
              </div>
              <div class="stat-label">Deleted Users</div>
              <div class="stat-value">
                <%= stats.deletedUsers %>
              </div>
              <div class="stat-change">✕ Removed</div>
            </div>
          </div>

          <div class="section-header">
            <span class="section-title">All Registered Users</span>
            <div style="font-size:13px; color:#6e8e8e">
              <%= users.length %> total users
            </div>
          </div>

          <div class="table-card">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Phone</th>
                  <th>Joined</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="users-table-body">
                <% users.forEach((u, i)=> { %>
                  <tr data-user-status="<%= u.memberStatus %>">
                    <td>
                      <%= i + 1 %>
                    </td>
                    <td>
                      <div style="display:flex;align-items:center;gap:10px">
                        <div
                          style="width:30px;height:30px;border-radius:50%;background:var(--teal-pale);color:var(--teal);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600">
                          <%= (u.memberNick || '?' ).slice(0, 2).toUpperCase() %>
                        </div>
                        <%= u.memberNick %>
                      </div>
                    </td>
                    <td>
                      <%= u.memberPhone %>
                    </td>
                    <td>
                      <%= new Date(u.createdAt).toLocaleDateString('en-US', { month: 'short' , day: 'numeric' ,
                        year: 'numeric' }) %>
                    </td>
                    <td>
                      <select class="status-select" data-id="<%= u._id %>" data-type="user">
                        <option value="ACTIVE" <%=u.memberStatus==='ACTIVE' ? 'selected' : '' %>>ACTIVE</option>
                        <option value="BLOCKED" <%=u.memberStatus==='BLOCKED' ? 'selected' : '' %>>BLOCKED</option>
                        <option value="DELETED" <%=u.memberStatus==='DELETED' ? 'selected' : '' %>>DELETED</option>
                      </select>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </main>

  </div>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <script src="/js/utils.js"></script>
  <script src="/js/member.js"></script>
  <script src="/js/init.js"></script>
</body>

</html>